{
  "name": "Canvas Chat",
  "image": "mcr.microsoft.com/devcontainers/universal:2",

  // Clone pi-mono as a sibling repo (required file dependency)
  // Result: /workspaces/repos/pi-mono  and  /workspaces/apps/canvas-chat
  "initializeCommand": "mkdir -p ${localWorkspaceFolder}/../../repos",
  "postCreateCommand": ".devcontainer/setup.sh",

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Canvas Chat dev server",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },

  "remoteEnv": {
    // Uncomment and set if using an API key instead of OAuth (PI_AUTH_JSON takes priority)
    // "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY}"
  }
}

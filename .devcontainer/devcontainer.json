{
  "name": "Canvas Chat",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/apps/canvas-chat,type=bind,consistency=cached",
  "workspaceFolder": "/workspaces/apps/canvas-chat",

  // Match the workspace layout expected by the repo and keep sibling references in /workspaces/repos.
  "initializeCommand": "true",
  "postCreateCommand": ".devcontainer/setup.sh",

  "forwardPorts": [3000],
  "portsAttributes": {
    "3000": {
      "label": "Canvas Chat dev server",
      "onAutoForward": "openBrowser"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },

  "remoteEnv": {
    "NVM_DIR": "/usr/local/share/nvm",
    "PNPM_HOME": "/usr/local/share/pnpm",
    "PATH": "/usr/local/share/pnpm:/usr/local/share/nvm/versions/node/v24.14.1/bin:${containerEnv:PATH}"
  }
}
